OPENROUTER_API_KEY=sk-or-...
RAPIDAPI_KEY=...
CV_URL=https://example.com/your-cv.pdf  # Optional, used for CLI only

# Telegram Bot
BOT_TOKEN=your-telegram-bot-token

# Mini App frontend URL (e.g. https://jobs.example.com)
WEBAPP_URL=http://localhost:5173

# SQLite DB path (relative to project root)
DB_PATH=.swipe-to-hire.db

# Fastify API port
API_PORT=3421

# LangSmith (optional, recommended)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<your-api-key>
LANGSMITH_PROJECT="swipe-to-hire"
