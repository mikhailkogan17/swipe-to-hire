{
  "name": "@swipe-to-hire/backend",
  "version": "0.1.1",
  "description": "LangGraph hr pipeline + Telegram bot backend",
  "homepage": "https://github.com/mikhailkogan17/swipe-to-hire#readme",
  "bugs": {
    "url": "https://github.com/mikhailkogan17/swipe-to-hire/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikhailkogan17/swipe-to-hire.git"
  },
  "license": "MIT",
  "author": "Mikhail Kogan",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "bot": "npm run start --workspace=@swipe-to-hire/bot",
    "dev": "npm run dev --workspace=@swipe-to-hire/bot",
    "cli": "npm run start --workspace=@swipe-to-hire/cli",
    "build:miniapp": "npm run build --workspace=@swipe-to-hire/miniapp",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "vitest run",
    "test:watch": "vitest --project unit",
    "lint": "eslint packages --ext .ts,.tsx",
    "lint:fix": "eslint packages --ext .ts,.tsx --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json}\"",
    "typecheck": "tsc --noEmit",
    "release": "node scripts/release.js --bump-type=patch",
    "release:minor": "node scripts/release.js --bump-type=minor",
    "release:major": "node scripts/release.js --bump-type=major",
    "rpi": "ssh ${RPI_HOST:-pi@raspberrypi.local} \"cd ${RPI_DIR:-/home/pi/swipe-to-hire} && git pull && docker-compose up -d --build bot\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@langchain/community": "^1.1.24",
    "@langchain/core": "^1.1.34",
    "@langchain/langgraph": "^1.2.3",
    "@langchain/langgraph-checkpoint": "^1.0.1",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.3.0",
    "@langchain/openrouter": "^0.1.7",
    "@swipe-to-hire/types": "*",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.4",
    "langchain": "^1.2.35",
    "mbox-parser": "^1.0.1",
    "node-cron": "^4.2.1",
    "pdf-parse": "^1.1.4",
    "telegraf": "^4.16.3",
    "yesno": "^0.4.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "zod": "^4.3.0",
    "pdf-parse": "^1.1.4"
  }
}
